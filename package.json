{
  "name": "coloma",
  "private": true,
  "version": "0.1.0",
  "license": "Apache-2.0",
  "description": "The Continuous Verification and Optimization layer for self-hosted LLMs",
  "author": "Coloma Labs",
  "repository": {
    "type": "git",
    "url": "https://github.com/colomalabs/coloma.git"
  },
  "type": "module",
  "scripts": {
    "dev": "concurrently --kill-others --names backend,frontend --prefix-colors cyan,green \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "uv run uvicorn backend.main:app --host 0.0.0.0 --port 8001 --reload",
    "dev:frontend": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build",
    "lint": "eslint src",
    "start": "concurrently --kill-others --names backend,frontend --prefix-colors cyan,green \"npm run start:backend\" \"npm run start:frontend\"",
    "start:backend": "uv run uvicorn backend.main:app --host 0.0.0.0 --port 8001",
    "start:frontend": "vite preview --host 0.0.0.0 --open"
  },
  "dependencies": {
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@radix-ui/react-slot": "^1.1.1",
    "@tanstack/react-query": "^5.101.2",
    "@uiw/react-codemirror": "^4.25.10",
    "@vitejs/plugin-react": "^4.3.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.5.5",
    "tailwindcss-animate": "^1.0.7",
    "vite": "^6.0.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "concurrently": "^10.0.3",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.64.0"
  }
}
